{
  "info": {
    "name": "InsureVoice — End-to-End Test Suite",
    "description": "Full end-to-end tests for the InsureVoice multi-agent pipeline.\n\nTest order for a full E2E run:\n1. Health checks (all services)\n2. MCP search (direct)\n3. Compliance check (direct)\n4. Rank products (direct)\n5. Agent happy-path (orchestrated)\n6. Agent multi-turn\n7. Agent all-rejected (guardrail)\n\nEnvironment variables required:\n  AGENT_URL, MCP_URL, COMPLIANCE_URL, RANK_URL\n\nUpdate the 'InsureVoice - Local' or 'InsureVoice - Prod' environment before running.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "session_id",
      "value": "",
      "type": "string",
      "description": "Auto-populated by the Agent Happy Path request. Reused for multi-turn tests."
    }
  ],
  "item": [
    {
      "name": "1 — Health Checks",
      "item": [
        {
          "name": "Agent /health",
          "request": {
            "method": "GET",
            "url": "{{AGENT_URL}}/health"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.test('status ok', () => pm.expect(b.status).to.eql('ok'));",
                  "pm.test('project present', () => pm.expect(b.project).to.be.a('string'));",
                  "pm.test('location present', () => pm.expect(b.location).to.be.a('string'));"
                ]
              }
            }
          ]
        },
        {
          "name": "Elastic MCP /health",
          "request": {
            "method": "GET",
            "url": "{{MCP_URL}}/health"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('status ok', () => pm.expect(pm.response.json().status).to.eql('ok'));"
                ]
              }
            }
          ]
        },
        {
          "name": "compliance-check /health",
          "request": {
            "method": "GET",
            "url": "{{COMPLIANCE_URL}}/health"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200 or 404 (no /health on CF)', () => {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 404]);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "rank-products /health",
          "request": {
            "method": "GET",
            "url": "{{RANK_URL}}/health"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200 or 404 (no /health on CF)', () => {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 404]);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "2 — Elastic MCP (direct)",
      "item": [
        {
          "name": "MCP search — term life, 35yo non-smoker",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{MCP_URL}}/search_products",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"term life cover for family of four non-smoker\",\n  \"customer_age\": 35,\n  \"is_smoker\": false,\n  \"income\": 1200000,\n  \"size\": 5\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.test('candidates array present', () => pm.expect(b.candidates).to.be.an('array'));",
                  "pm.test('at least 1 candidate', () => pm.expect(b.candidates.length).to.be.above(0));",
                  "pm.test('elser_score present', () => pm.expect(b.candidates[0]).to.have.property('elser_score'));",
                  "pm.test('product_id present', () => pm.expect(b.candidates[0]).to.have.property('product_id'));",
                  "// Save first candidate for use in compliance/rank tests",
                  "pm.collectionVariables.set('search_candidates', JSON.stringify(b.candidates.slice(0, 5)));"
                ]
              }
            }
          ]
        },
        {
          "name": "MCP search — health cover, diabetic",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{MCP_URL}}/search_products",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"health insurance for diabetic senior\",\n  \"customer_age\": 62,\n  \"is_smoker\": false,\n  \"income\": 600000,\n  \"size\": 5\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.test('candidates array', () => pm.expect(b.candidates).to.be.an('array'));"
                ]
              }
            }
          ]
        },
        {
          "name": "MCP search — validation error (missing income)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{MCP_URL}}/search_products",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"term life\",\n  \"customer_age\": 35,\n  \"is_smoker\": false\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));",
                  "pm.test('error field present', () => pm.expect(pm.response.json()).to.have.property('error'));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "3 — Compliance Check (direct)",
      "item": [
        {
          "name": "Compliance — eligible 35yo",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{COMPLIANCE_URL}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"candidate_products\": [\n    {\n      \"product_id\": \"TERM001\",\n      \"name\": \"SecureLife Term Plan\",\n      \"product_type\": \"term_life\",\n      \"min_age\": 18,\n      \"max_age\": 65,\n      \"min_income\": 300000,\n      \"smoker_eligible\": true,\n      \"medical_required_above\": 10000000,\n      \"is_active\": true,\n      \"elser_score\": 0.85\n    },\n    {\n      \"product_id\": \"TERM002\",\n      \"name\": \"SeniorShield Term\",\n      \"product_type\": \"term_life\",\n      \"min_age\": 55,\n      \"max_age\": 70,\n      \"min_income\": 300000,\n      \"smoker_eligible\": false,\n      \"medical_required_above\": 5000000,\n      \"is_active\": true,\n      \"elser_score\": 0.60\n    }\n  ],\n  \"customer_profile\": {\n    \"age\": 35,\n    \"smoker\": false,\n    \"income\": 1200000,\n    \"sum_need\": 5000000\n  }\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.test('passed array present', () => pm.expect(b.passed).to.be.an('array'));",
                  "pm.test('rejected array present', () => pm.expect(b.rejected).to.be.an('array'));",
                  "pm.test('TERM001 passes (age 35 in 18-65)', () => {",
                  "  const ids = b.passed.map(p => p.product_id);",
                  "  pm.expect(ids).to.include('TERM001');",
                  "});",
                  "pm.test('TERM002 rejected (min_age 55 > customer 35)', () => {",
                  "  const ids = b.rejected.map(p => p.product_id);",
                  "  pm.expect(ids).to.include('TERM002');",
                  "});",
                  "pm.test('rejected entry has reasons', () => {",
                  "  const r = b.rejected.find(p => p.product_id === 'TERM002');",
                  "  pm.expect(r.reasons).to.be.an('array').with.length.above(0);",
                  "});",
                  "// Save passed products for rank test",
                  "pm.collectionVariables.set('passed_products', JSON.stringify(b.passed));"
                ]
              }
            }
          ]
        },
        {
          "name": "Compliance — all rejected (age 72)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{COMPLIANCE_URL}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"candidate_products\": [\n    {\n      \"product_id\": \"TERM001\",\n      \"name\": \"SecureLife Term Plan\",\n      \"product_type\": \"term_life\",\n      \"min_age\": 18,\n      \"max_age\": 65,\n      \"min_income\": 300000,\n      \"smoker_eligible\": true,\n      \"medical_required_above\": 10000000,\n      \"is_active\": true,\n      \"elser_score\": 0.85\n    }\n  ],\n  \"customer_profile\": {\n    \"age\": 72,\n    \"smoker\": false,\n    \"income\": 1200000,\n    \"sum_need\": 5000000\n  }\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.test('passed is empty', () => pm.expect(b.passed).to.eql([]));",
                  "pm.test('TERM001 rejected (max_age 65 < customer 72)', () => {",
                  "  pm.expect(b.rejected.length).to.eql(1);",
                  "  pm.expect(b.rejected[0].product_id).to.eql('TERM001');",
                  "});",
                  "pm.test('rejection reason mentions age', () => {",
                  "  const reason = b.rejected[0].reasons.join(' ').toLowerCase();",
                  "  pm.expect(reason).to.include('age');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Compliance — smoker exclusion",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{COMPLIANCE_URL}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"candidate_products\": [\n    {\n      \"product_id\": \"HEALTH001\",\n      \"name\": \"ClearHealth Plan\",\n      \"product_type\": \"health\",\n      \"min_age\": 18,\n      \"max_age\": 65,\n      \"min_income\": 200000,\n      \"smoker_eligible\": false,\n      \"medical_required_above\": 5000000,\n      \"is_active\": true,\n      \"elser_score\": 0.77\n    }\n  ],\n  \"customer_profile\": {\n    \"age\": 40,\n    \"smoker\": true,\n    \"income\": 800000,\n    \"sum_need\": 1000000\n  }\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.test('passed is empty (smoker excluded)', () => pm.expect(b.passed).to.eql([]));",
                  "pm.test('reason mentions smoker', () => {",
                  "  const reason = b.rejected[0].reasons.join(' ').toLowerCase();",
                  "  pm.expect(reason).to.include('smoker');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Compliance — validation error (missing age)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{COMPLIANCE_URL}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"candidate_products\": [],\n  \"customer_profile\": {\n    \"smoker\": false,\n    \"income\": 1200000\n  }\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "4 — Rank Products (direct)",
      "item": [
        {
          "name": "Rank — 3 products, income match",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{RANK_URL}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"passed_products\": [\n    {\n      \"product_id\": \"TERM001\",\n      \"name\": \"SecureLife Term Plan\",\n      \"product_type\": \"term_life\",\n      \"min_age\": 18,\n      \"max_age\": 65,\n      \"min_income\": 300000,\n      \"annual_premium_inr\": 8000,\n      \"sum_assured_inr\": 10000000,\n      \"smoker_eligible\": true,\n      \"is_active\": true,\n      \"elser_score\": 0.85\n    },\n    {\n      \"product_id\": \"TERM002\",\n      \"name\": \"FamilyShield Plus\",\n      \"product_type\": \"term_life\",\n      \"min_age\": 21,\n      \"max_age\": 65,\n      \"min_income\": 500000,\n      \"annual_premium_inr\": 9500,\n      \"sum_assured_inr\": 15000000,\n      \"smoker_eligible\": false,\n      \"is_active\": true,\n      \"elser_score\": 0.72\n    },\n    {\n      \"product_id\": \"TERM003\",\n      \"name\": \"PureProtect Term\",\n      \"product_type\": \"term_life\",\n      \"min_age\": 18,\n      \"max_age\": 75,\n      \"min_income\": 250000,\n      \"annual_premium_inr\": 7200,\n      \"sum_assured_inr\": 8000000,\n      \"smoker_eligible\": true,\n      \"is_active\": true,\n      \"elser_score\": 0.68\n    }\n  ],\n  \"customer_profile\": {\n    \"age\": 35,\n    \"smoker\": false,\n    \"income\": 1200000,\n    \"sum_need\": 5000000\n  }\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.test('top3 array present', () => pm.expect(b.top3).to.be.an('array'));",
                  "pm.test('max 3 results', () => pm.expect(b.top3.length).to.be.at.most(3));",
                  "pm.test('rank field present', () => pm.expect(b.top3[0]).to.have.property('rank'));",
                  "pm.test('suitability_score present', () => pm.expect(b.top3[0]).to.have.property('suitability_score'));",
                  "pm.test('score_breakdown present', () => pm.expect(b.top3[0]).to.have.property('score_breakdown'));",
                  "pm.test('audit present', () => pm.expect(b.audit).to.be.an('object'));",
                  "pm.test('audit has customer_profile_hash (no PII)', () => {",
                  "  pm.expect(b.audit.customer_profile_hash).to.be.a('string');",
                  "  pm.expect(b.audit).to.not.have.property('customer_age');",
                  "  pm.expect(b.audit).to.not.have.property('income');",
                  "});",
                  "pm.test('highest score is rank 1', () => {",
                  "  if (b.top3.length >= 2) {",
                  "    pm.expect(b.top3[0].suitability_score).to.be.at.least(b.top3[1].suitability_score);",
                  "  }",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Rank — single product (edge case)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{RANK_URL}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"passed_products\": [\n    {\n      \"product_id\": \"TERM001\",\n      \"name\": \"SecureLife Term Plan\",\n      \"product_type\": \"term_life\",\n      \"min_age\": 18,\n      \"max_age\": 65,\n      \"min_income\": 300000,\n      \"annual_premium_inr\": 8000,\n      \"sum_assured_inr\": 10000000,\n      \"smoker_eligible\": true,\n      \"is_active\": true,\n      \"elser_score\": 0.85\n    }\n  ],\n  \"customer_profile\": {\n    \"age\": 35,\n    \"smoker\": false,\n    \"income\": 1200000,\n    \"sum_need\": 5000000\n  }\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('top3 has exactly 1 entry', () => pm.expect(pm.response.json().top3.length).to.eql(1));"
                ]
              }
            }
          ]
        },
        {
          "name": "Rank — validation error (missing passed_products)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{RANK_URL}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customer_profile\": { \"age\": 35, \"smoker\": false, \"income\": 1200000 }\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "5 — Agent: Happy Path",
      "item": [
        {
          "name": "Invoke — complete profile, term life",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{AGENT_URL}}/invoke",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"I am 35 years old, non-smoker, annual income 1.2 million INR. I need term life cover for my family of four.\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.test('session_id present', () => pm.expect(b.session_id).to.be.a('string').with.length.above(0));",
                  "pm.test('response text present', () => pm.expect(b.response).to.be.a('string').with.length.above(10));",
                  "pm.test('response <= 120 words (TTS comfort)', () => {",
                  "  const words = b.response.split(/\\s+/).length;",
                  "  pm.expect(words).to.be.at.most(120);",
                  "});",
                  "// Save session_id for multi-turn tests",
                  "pm.collectionVariables.set('session_id', b.session_id);",
                  "console.log('session_id:', b.session_id);",
                  "console.log('response:', b.response);"
                ]
              }
            }
          ]
        },
        {
          "name": "Invoke — health insurance, senior 58yo",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{AGENT_URL}}/invoke",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"I am 58 years old, non-smoker, income 800000 INR per year. Looking for health insurance coverage.\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.test('session_id present', () => pm.expect(b.session_id).to.be.a('string'));",
                  "pm.test('response present', () => pm.expect(b.response).to.be.a('string').with.length.above(10));"
                ]
              }
            }
          ]
        },
        {
          "name": "Invoke — latency gate (< 8 seconds)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{AGENT_URL}}/invoke",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"I am 42 years old, smoker, income 2 million INR. Need retirement savings plan.\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('End-to-end latency < 8000 ms (Constitution §III)', () => {",
                  "  pm.expect(pm.response.responseTime).to.be.below(8000);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "6 — Agent: Multi-Turn",
      "item": [
        {
          "name": "Follow-up — tell me more about the first one",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{AGENT_URL}}/invoke",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"Tell me more about the first one.\",\n  \"session_id\": \"{{session_id}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const sid = pm.collectionVariables.get('session_id');",
                  "if (!sid) { throw new Error('Run \"Invoke — complete profile\" first to get a session_id'); }"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const b = pm.response.json();",
                  "pm.test('same session_id returned', () => pm.expect(b.session_id).to.eql(pm.collectionVariables.get('session_id')));",
                  "pm.test('response is contextual (non-empty)', () => pm.expect(b.response.length).to.be.above(20));"
                ]
              }
            }
          ]
        },
        {
          "name": "Follow-up — what is the premium for the second option",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{AGENT_URL}}/invoke",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"What is the annual premium for the second option?\",\n  \"session_id\": \"{{session_id}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('response contains INR or rupee mention', () => {",
                  "  const resp = pm.response.json().response.toLowerCase();",
                  "  pm.expect(resp).to.satisfy(r => r.includes('₹') || r.includes('inr') || r.includes('rupee') || r.includes('premium'));",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Profile reset — start over with new budget",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{AGENT_URL}}/invoke",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"Let me start over. I am 40 years old, non-smoker, new income is 2.5 million INR. Looking for retirement savings.\",\n  \"session_id\": \"{{session_id}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
