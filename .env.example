# =============================================================================
# InsureVoice — Environment Configuration Example
# =============================================================================
# Copy this file to '.env' and fill in your actual Elasticsearch credentials.
# The GCP configuration is pre-linked to 'voice-sales-agent'.

# -----------------------------------------------------------------------------
# Google Cloud Platform Configuration
# -----------------------------------------------------------------------------
# The GCP Project ID linked to this codebase
GCP_PROJECT_ID=voice-sales-agent

# The default deployment region for Cloud Functions
GCP_REGION=us-central1

# -----------------------------------------------------------------------------
# Deployed Cloud Function URLs
# -----------------------------------------------------------------------------
# These are the HTTPS endpoints for your deployed Cloud Functions in voice-sales-agent.
# Update these if you deploy to a different region or project.
COMPLIANCE_CHECK_URL=https://us-central1-voice-sales-agent.cloudfunctions.net/compliance_check
RANK_PRODUCTS_URL=https://us-central1-voice-sales-agent.cloudfunctions.net/rank_products
# Set this after running Cloud Build — value printed in Step 2b build logs and Step 7 summary
ELASTIC_MCP_SERVER_URL=https://<elastic-mcp-server-url>.run.app

# -----------------------------------------------------------------------------
# Elasticsearch Cloud Connection
# -----------------------------------------------------------------------------
# Your Elasticsearch Cloud deployment URL (with port, usually 443)
ES_URL=https://your-elastic-deployment.es.io:443

# Your Elasticsearch API Key with read/write permissions for the product catalog
ES_API_KEY=your_elasticsearch_api_key_here
